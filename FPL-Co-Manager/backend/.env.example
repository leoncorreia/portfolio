# Copy to .env and fill in real values. Never commit .env.

# --- FPL ---
FPL_BASE_URL=https://fantasy.premierleague.com/api

# --- Local structured history (SQLite) ---
DATABASE_URL=sqlite:///./fpl_comanager.db

# --- GMI Cloud — inference API (Bearer). Kimi via model ids below. ---
GMI_API_KEY=placeholder
GMI_BASE_URL=https://api.gmi-serving.com/v1
# GMI_ORGANIZATION_ID=

KIMI_MODEL=kimi-k2-5
KIMI_VISION_MODEL=kimi-k2-5

# --- Dify — POST /workflows/run after each analyze ---
DIFY_API_KEY=placeholder
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_TIMEOUT_SECONDS=120
DIFY_INPUT_SQUAD=squad
DIFY_INPUT_RECOMMENDATION=recommendation
DIFY_INPUT_DETERMINISTIC=deterministic_explanation
DIFY_INPUT_USER_ID=user_id
# Optional: one Paragraph on START + use / in LLM to insert this variable only
# DIFY_INPUT_BUNDLE=fpl_context

# --- HydraDB ---
HYDRADB_API_KEY=placeholder
HYDRADB_BASE_URL=https://api.hydradb.com
HYDRADB_TENANT_ID=
HYDRADB_INFER_ON_WRITE=false
HYDRADB_MAX_RESULTS=15

HYDRA_DATABASE_URL=placeholder

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
